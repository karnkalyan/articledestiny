# Database connection URL (using MySQL for local development)
# Format: mysql://<user>:<password>@<host>:<port>/<database>
# Empty password example for local root: mysql://root@localhost:3306/articledestiny
DATABASE_URL="mysql://root@localhost:3306/articledestiny"

# Secret key used for signing JWT login items
JWT_SECRET="super-secret-auth-key-change-in-production"
